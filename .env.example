# Copy this file to .env and fill in your real key:  cp .env.example .env
# .env is gitignored, so your key never gets committed.

# Dify app API key — find it in the Dify UI: your App → API Access → API Key
DIFY_API_KEY=app-your-key-here

# Anthropic API key — used by score_results.py for GPTScore (LLM-as-Judge)
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — used by ragas_eval.py (RAGAS uses OpenAI internally for its LLM judge calls)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
