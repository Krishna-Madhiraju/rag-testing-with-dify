# Copy this file to .env and fill in your real key:  cp .env.example .env
# .env is gitignored, so your key never gets committed.

# Dify app API key — find it in the Dify UI: your App → API Access → API Key
DIFY_API_KEY=app-your-key-here

# Anthropic API key — used by score_results.py (GPTScore) and ragas_eval.py (RAGAS judge)
# Get yours at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
